# Substack Configuration (Required)
SUBSTACK_USER="@your_username"  # Your Substack username (with or without @)
SUBSTACK_COOKIE="your_substack_session_cookie_here"

# AI Labeling (Required for Claude-powered categorization)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values
# 3. To get your Substack cookie:
#    - Log into substack.com in your browser
#    - Open Developer Tools (F12)
#    - Go to Application/Storage > Cookies > https://substack.com
#    - Copy the entire cookie string
# 4. To get your Anthropic API key:
#    - Go to https://console.anthropic.com/
#    - Create an API key in Settings > API Keys
